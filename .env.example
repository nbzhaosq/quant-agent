# Quant Agent Configuration
# Copy this file to .env and fill in your values

# Tushare Token (required - get from https://tushare.pro)
TUSHARE_TOKEN=your_tushare_token_here

# Analysis settings (optional)
# MAX_HISTORY_DAYS=365
# DEFAULT_MARKET=cn

# Claude / Anthropic API (required for QuantAgent)
# For OpenAI compatible APIs (e.g., GLM, DeepSeek):
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=glm-5

# Neo4j / Graphiti
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
GRAPHITI_DATABASE=quant_research

# SQLite / Vector Store
SQLITE_DB_PATH=data/quant.db
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# LLM for Graphiti
GRAPHITI_LLM_MODEL=gpt-4.1-mini
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=your_openai_key_here
